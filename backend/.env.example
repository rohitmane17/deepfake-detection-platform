# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/neurox-ai
# Alternative: MongoDB Atlas connection
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/neurox-ai?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email Configuration (for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@neurox-ai.com
ADMIN_EMAIL=your-admin-email@gmail.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,video/avi,video/mov

# Deepfake Detection API (if using external service)
DEEPFAKE_API_KEY=your-deepfake-api-key
DEEPFAKE_API_URL=https://api.deepfake-detection.com
